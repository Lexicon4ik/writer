# ============================================================
# NewsBot Writer — шаблон конфигурации
# Скопируйте в .env и заполните значениями
# ============================================================

# --- Application -------------------------------------------------
# Ключ шифрования (base64, 32 байта). Сгенерировать: php bin/generate-key.php
APP_KEY=base64:CHANGE_THIS_TO_RANDOM_32_BYTES_KEY

# --- Database ----------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=newsbot_writer
DB_USER=newsbot
DB_PASS=secret

# --- Scraper -----------------------------------------------------
# Задержка между запросами к одному домену (миллисекунды)
# Рекомендуется не ниже 1000, чтобы не получить бан
FETCH_DOMAIN_DELAY_MS=1500
