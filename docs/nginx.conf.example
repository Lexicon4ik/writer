# NewsBot Writer - Nginx Configuration Example
# Domain: writer.lexik.online
#
# Usage:
#   1. Copy this file to /etc/nginx/sites-available/writer.lexik.online.conf
#   2. Create symlink: ln -s /etc/nginx/sites-available/writer.lexik.online.conf /etc/nginx/sites-enabled/
#   3. Test config: nginx -t
#   4. Reload Nginx: systemctl reload nginx
#
# SSL Certificate (Let's Encrypt):
#   sudo certbot --nginx -d writer.lexik.online

# HTTP to HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name writer.lexik.online;

    # Let's Encrypt challenge
    location /.well-known/acme-challenge/ {
        root /var/www/html/writer/web/public;
    }

    location / {
        return 301 https://$server_name$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name writer.lexik.online;

    # Document root
    root /var/www/html/writer/web/public;
    index index.php;

    # SSL configuration (managed by Certbot)
    ssl_certificate /etc/letsencrypt/live/writer.lexik.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/writer.lexik.online/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Logging
    access_log /var/www/html/writer/logs/nginx_access.log;
    error_log /var/www/html/writer/logs/nginx_error.log;

    # Security headers (additional to those set by PHP)
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml;

    # Main location - try files, then index.php
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Health check endpoint (separate file)
    location = /health.php {
        fastcgi_pass unix:/run/php/php8.1-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
    }

    # PHP handling
    location ~ \.php$ {
        # Prevent PHP execution in uploads
        location ~ ^/uploads/ {
            deny all;
        }

        fastcgi_pass unix:/run/php/php8.1-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
        include fastcgi_params;

        # Timeouts
        fastcgi_connect_timeout 60;
        fastcgi_send_timeout 180;
        fastcgi_read_timeout 180;

        # Buffer settings
        fastcgi_buffer_size 128k;
        fastcgi_buffers 4 256k;
        fastcgi_busy_buffers_size 256k;
    }

    # Static files caching
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Deny access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Deny access to sensitive files
    location ~* (\.env|\.git|\.htaccess|composer\.(json|lock))$ {
        deny all;
    }

    # Block access to PHP files in certain directories
    location ~* ^/(config|src|migrations|tests|vendor)/ {
        deny all;
    }
}
